{
  "schemaVersion": 1,
  "roles": ["USER", "ARCHITECT", "ADMIN"],
  "workflows": [
    {
      "id": "authentication-and-navigation",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["success", "keyboard-only", "role-specific-surface", "unauthorized-control-hidden"]
    },
    {
      "id": "requirement-analysis",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["empty", "loading", "success", "partial", "stale", "provider-error", "live-announcement"]
    },
    {
      "id": "proposal-review",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["forbidden", "pending", "accepted", "rejected", "reverted", "bulk-accepted"]
    },
    {
      "id": "relation-management",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["read-only", "created", "duplicate-conflict", "delete-confirmed", "foreign-mutation-forbidden"]
    },
    {
      "id": "framework-import",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["preview-success", "materialization-forbidden", "invalid-file-error"]
    },
    {
      "id": "document-import",
      "roles": ["ARCHITECT", "ADMIN"],
      "states": ["upload-loading", "candidate-review", "selection", "resource-limit-error"]
    },
    {
      "id": "export",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["download-success", "backend-error", "accessible-feedback"]
    },
    {
      "id": "password-change",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["confirmation-error", "success", "focus-preserved"]
    },
    {
      "id": "workspace-sync",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["up-to-date", "diverged-conflict", "remote-error", "offline", "publish-success", "admin-controls-only"]
    },
    {
      "id": "accessible-dialog",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["opened", "focus-contained", "closed", "focus-restored"]
    },
    {
      "id": "responsive-reflow",
      "roles": ["USER", "ARCHITECT", "ADMIN"],
      "states": ["mobile-portrait", "narrow-landscape", "zoom-200", "zoom-400", "text-spacing", "forced-colors", "reduced-motion"]
    }
  ],
  "profiles": [
