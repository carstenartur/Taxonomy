    {"id": "landscape-user-firefox", "browser": "firefox", "role": "USER", "width": 844, "height": 390, "zoom": 1, "forcedColors": false, "textSpacing": false},
    {"id": "zoom-200-user-chromium", "browser": "chromium", "role": "USER", "width": 1440, "height": 1000, "zoom": 2, "forcedColors": false, "textSpacing": false},
    {"id": "zoom-400-user-chromium", "browser": "chromium", "role": "USER", "width": 1440, "height": 1000, "zoom": 4, "forcedColors": false, "textSpacing": false},
    {"id": "text-spacing-admin-chromium", "browser": "chromium", "role": "ADMIN", "width": 1024, "height": 768, "zoom": 1, "forcedColors": false, "textSpacing": true},
    {"id": "forced-colors-architect-chromium", "browser": "chromium", "role": "ARCHITECT", "width": 1024, "height": 768, "zoom": 1, "forcedColors": true, "textSpacing": false}
